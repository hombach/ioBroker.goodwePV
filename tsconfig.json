// Root tsconfig — type checking only; compilation is configured in tsconfig.build.json
{
	"extends": "@tsconfig/node22/tsconfig.json",
	"compileOnSave": true,
	"compilerOptions": {
		"noEmit": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node", "mocha"],
		"allowImportingTsExtensions": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["build/**", "node_modules/**"]
}
