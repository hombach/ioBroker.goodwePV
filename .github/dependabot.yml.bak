version: 2
updates:

  - package-ecosystem: 'github-actions'
    directory: '/'
    open-pull-requests-limit: 15
    schedule:
      interval: 'weekly'
      time: "04:00"
      timezone: Europe/Berlin
    assignees:
      - FossyTom
    versioning-strategy: increase

  - package-ecosystem: 'npm'
    directory: '/'
    open-pull-requests-limit: 15
    schedule:
      interval: monthly
      time: "04:00"
      timezone: Europe/Berlin
    assignees:
      - FossyTom
